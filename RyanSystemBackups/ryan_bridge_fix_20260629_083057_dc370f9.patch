index 0000000..158000f
--- /dev/null
+++ b/work/ryan-tools/bin/ryan-open-screenshot
@@ -0,0 +1,175 @@
+#!/usr/bin/env zsh
+set -euo pipefail
+
+export PATH="/Users/oldking/.local/bin:/Users/oldking/.local/node-v24.16.0-darwin-arm64/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
+
+DEFAULT_WORKSPACE="/Users/oldking/Documents/Codex/RyanProjects/Warehouse"
+OUTBOX="${RYAN_OUTBOX:-$DEFAULT_WORKSPACE/.ryan-outbox}"
+RYAN_SEND="/Users/oldking/.local/bin/ryan-send"
+
+chat_args=()
+dry_run=0
+send_result=1
+wait_seconds=8
+
+usage() {
+  cat <<'EOF'
+Usage:
+  ryan-open-screenshot [--chat-id oc_xxx] [--wait seconds] [--no-send] [--dry-run] <app-name> [output.png]
+
+Examples:
+  ryan-open-screenshot 梦幻西游
+  ryan-open-screenshot --wait 12 梦幻西游 mhxy.png
+EOF
+}
+
+safe_name() {
+  /usr/bin/python3 - "$1" <<'PY'
+import re, sys
+name = sys.argv[1].strip() or "app"
+name = re.sub(r"[^\w.-]+", "_", name, flags=re.UNICODE).strip("._")
+print(name or "app")
+PY
+}
+
+realpath_portable() {
+  /usr/bin/perl -MCwd=abs_path -e 'print abs_path(shift)' "$1"
+}
+
+find_app() {
+  local query="$1"
+  if [[ -d "$query" ]]; then
+    realpath_portable "$query"
+    return
+  fi
+  local candidate
+  for candidate in \
+    "/Applications/${query}.app" \
+    "$HOME/Applications/${query}.app" \
+    "/Applications/梦幻西游.app"; do
+    if [[ -d "$candidate" ]]; then
+      case "$candidate" in
+        "/Applications/梦幻西游.app")
+          [[ "$query" == "梦幻西游" || "$query" == *"梦幻"* || "$query" == *"西游"* ]] || continue
+          ;;
+      esac
+      realpath_portable "$candidate"
+      return
+    fi
+  done
+
+  /usr/bin/python3 - "$query" <<'PY'
+import os, sys
+query = sys.argv[1].casefold()
+roots = ["/Applications", os.path.expanduser("~/Applications")]
+matches = []
+for root in roots:
+    if not os.path.isdir(root):
+        continue
+    for dirpath, dirnames, _filenames in os.walk(root):
+        depth = dirpath[len(root):].count(os.sep)
+        if depth >= 4:
+            dirnames[:] = []
+        for dirname in list(dirnames):
+            if not dirname.endswith(".app"):
+                continue
+            stem = dirname[:-4].casefold()
+            if query in stem or stem in query:
+                matches.append(os.path.join(dirpath, dirname))
+        if matches:
+            break
+    if matches:
+        break
+if matches:
+    print(os.path.realpath(matches[0]))
+PY
+}
+
+send_text_best_effort() {
+  local text="$1"
+  if [[ "$send_result" == "1" ]]; then
+    "$RYAN_SEND" "${chat_args[@]}" text "$text" >/dev/null 2>&1 || true
+  fi
+}
+
+send_image_best_effort() {
+  local image="$1"
+  if [[ "$send_result" == "1" ]]; then
+    "$RYAN_SEND" "${chat_args[@]}" image "$image" >/dev/null 2>&1 || true
+  fi
+}
+
+capture_current_screen() {
+  local target="$1"
+  /bin/mkdir -p "$OUTBOX"
+  /usr/sbin/screencapture -x "$target"
+}
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --chat-id)
+      [[ $# -ge 2 ]] || { usage; exit 2; }
+      chat_args=(--chat-id "$2")
+      shift 2
+      ;;
+    --wait)
+      [[ $# -ge 2 ]] || { usage; exit 2; }
+      wait_seconds="$2"
+      shift 2
+      ;;
+    --no-send)
+      send_result=0
+      shift
+      ;;
+    --dry-run)
+      dry_run=1
+      send_result=0
+      shift
+      ;;
+    -h|--help)
+      usage
+      exit 0
+      ;;
+    *)
+      break
+      ;;
+  esac
+done
+
+[[ $# -ge 1 ]] || { usage; exit 2; }
+
+app_query="$1"
+shift
+base_name="$(safe_name "$app_query")"
+target_name="${1:-${base_name}_screenshot_$(/bin/date '+%Y%m%d_%H%M%S').png}"
+[[ "$target_name" == *.png ]] || target_name="${target_name}.png"
+target="$OUTBOX/$target_name"
+
+app_path="$(find_app "$app_query" | sed -n '1p')"
+if [[ -z "$app_path" || ! -d "$app_path" ]]; then
+  failure_shot="$OUTBOX/${base_name}_not_found_$(/bin/date '+%Y%m%d_%H%M%S').png"
+  capture_current_screen "$failure_shot" || true
+  send_text_best_effort "Ryan 没找到这个 App：$app_query。已发当前桌面截图供你确认。"
+  [[ -f "$failure_shot" ]] && send_image_best_effort "$failure_shot"
+  printf 'APP_NOT_FOUND app=%s screenshot=%s\n' "$app_query" "$failure_shot" >&2
+  exit 1
+fi
+
+if [[ "$dry_run" == "1" ]]; then
+  printf 'APP_FOUND %s\n' "$app_path"
+  exit 0
+fi
+
+if ! /usr/bin/open "$app_path"; then
+  failure_shot="$OUTBOX/${base_name}_open_failed_$(/bin/date '+%Y%m%d_%H%M%S').png"
+  capture_current_screen "$failure_shot" || true
+  send_text_best_effort "Ryan 找到了 App，但启动失败：$app_query。已发当前桌面截图。"
+  [[ -f "$failure_shot" ]] && send_image_best_effort "$failure_shot"
+  printf 'APP_OPEN_FAILED app=%s path=%s screenshot=%s\n' "$app_query" "$app_path" "$failure_shot" >&2
+  exit 1
+fi
+
+/bin/sleep "$wait_seconds"
+capture_current_screen "$target"
+send_image_best_effort "$target"
+printf 'OK app=%s path=%s screenshot=%s\n' "$app_query" "$app_path" "$target"
